#!/usr/bin/env bash
#
# claude-sandbox — Run Claude Code off-leash in isolated Docker containers.
#
set -euo pipefail

VERSION="0.1.0"
IMAGE="claude-sandbox:latest"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Defaults
DEFAULT_MEMORY="4g"
DEFAULT_CPUS="2"
DEFAULT_NETWORK="host"

# Repo search paths (override with CLAUDE_SANDBOX_REPO_DIRS)
DEFAULT_REPO_DIRS="${HOME}/Repos:${HOME}/repos:${HOME}/projects:${HOME}/src:${HOME}/code:${HOME}/dev:${HOME}/work"
REPO_DIRS="${CLAUDE_SANDBOX_REPO_DIRS:-$DEFAULT_REPO_DIRS}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

log()   { echo -e "${GREEN}▸${RESET} $*"; }
warn()  { echo -e "${YELLOW}▸${RESET} $*" >&2; }
error() { echo -e "${RED}✖${RESET} $*" >&2; }
dim()   { echo -e "${DIM}$*${RESET}"; }

# ─── Preflight ────────────────────────────────────────────────────────────────

check_docker() {
    if ! command -v docker &>/dev/null; then
        error "Docker is not installed."
        echo ""
        echo -e "  Install it from: ${BOLD}https://docs.docker.com/get-docker/${RESET}"
        echo ""
        exit 1
    fi

    if ! docker info &>/dev/null 2>&1; then
        error "Docker is not running."
        echo ""
        echo -e "  Start Docker Desktop or run: ${BOLD}sudo systemctl start docker${RESET}"
        echo ""
        exit 1
    fi
}

# ─── Secrets Scanner ─────────────────────────────────────────────────────────

SENSITIVE_FILES=(
    ".env"
    ".env.local"
    ".env.production"
    ".env.staging"
    ".env.development"
    "*.pem"
    "*.key"
    "*.p12"
    "*.pfx"
    "*.jks"
    "id_rsa"
    "id_ed25519"
    "id_ecdsa"
    "id_dsa"
    ".npmrc"
    ".pypirc"
    ".netrc"
    ".docker/config.json"
    "credentials.json"
    "service-account*.json"
    "gcloud-service-key.json"
    "secrets.yml"
    "secrets.yaml"
    "vault.yml"
    "vault.yaml"
    ".htpasswd"
    "*.keystore"
    "token.json"
)

SECRET_PATTERNS=(
    'ANTHROPIC_API_KEY\s*='
    'OPENAI_API_KEY\s*='
    'sk-ant-[a-zA-Z0-9]'
    'sk-[a-zA-Z0-9]{20,}'
    'AKIA[0-9A-Z]{16}'
    'aws_secret_access_key\s*='
    'ghp_[a-zA-Z0-9]{36}'
    'gho_[a-zA-Z0-9]{36}'
    'github_pat_[a-zA-Z0-9]'
    'glpat-[a-zA-Z0-9]'
    'xoxb-[0-9]'
    'xoxp-[0-9]'
    'xapp-[0-9]'
    'PRIVATE KEY-----'
    'password\s*[:=]\s*["\x27][^\s]'
    'secret\s*[:=]\s*["\x27][^\s]'
    'token\s*[:=]\s*["\x27][^\s]'
    'database_url\s*=\s*postgres'
    'mongodb(\+srv)?://[^/\s]+:[^/\s]+@'
    'redis://[^/\s]*:[^/\s]+@'
)

scan_secrets() {
    local repo_path="$1"
    local findings=()

    # Check for sensitive files
    for pattern in "${SENSITIVE_FILES[@]}"; do
        while IFS= read -r match; do
            [[ -z "$match" ]] && continue
            # Skip if in .git directory
            [[ "$match" == *"/.git/"* ]] && continue
            # Skip if in node_modules
            [[ "$match" == *"/node_modules/"* ]] && continue
            local relative="${match#$repo_path/}"
            findings+=("${YELLOW}file${RESET}  $relative")
        done < <(find "$repo_path" -maxdepth 4 -name "$pattern" -type f 2>/dev/null)
    done

    # Check for secret patterns in tracked files
    if command -v git &>/dev/null && [[ -d "$repo_path/.git" ]]; then
        local tracked_files
        tracked_files=$(git -C "$repo_path" ls-files 2>/dev/null)

        if [[ -n "$tracked_files" ]]; then
            for pat in "${SECRET_PATTERNS[@]}"; do
                while IFS=: read -r file line_content; do
                    [[ -z "$file" ]] && continue
                    [[ "$file" == *".lock"* ]] && continue
                    [[ "$file" == *"node_modules"* ]] && continue
                    [[ "$file" == *".min.js"* ]] && continue
                    # Truncate long matches
                    local preview="${line_content:0:60}"
                    [[ ${#line_content} -gt 60 ]] && preview="${preview}..."
                    preview=$(echo "$preview" | sed 's/[[:space:]]*$//')
                    findings+=("${RED}key${RESET}   $file  ${DIM}${preview}${RESET}")
                done < <(cd "$repo_path" && echo "$tracked_files" | xargs grep -IHn -E "$pat" 2>/dev/null | head -5)
            done
        fi
    fi

    if [[ ${#findings[@]} -eq 0 ]]; then
        return 1
    fi

    # Deduplicate
    local seen=()
    local unique=()
    for f in "${findings[@]}"; do
        local key="${f%%  *}"
        local found=false
        for s in "${seen[@]:-}"; do
            [[ "$s" == "$f" ]] && found=true && break
        done
        if [[ "$found" == false ]]; then
            seen+=("$f")
            unique+=("$f")
        fi
    done

    echo ""
    echo -e "${YELLOW}${BOLD}  ⚠  Sensitive data detected in this repo${RESET}"
    echo ""
    echo -e "  Claude will have ${BOLD}full read-write access${RESET} to these files inside the sandbox."
    echo -e "  It could read, modify, or accidentally expose secrets in prompts."
    echo ""

    local count=0
    for f in "${unique[@]}"; do
        echo -e "  $f"
        ((count++))
        if [[ $count -ge 20 ]]; then
            local remaining=$(( ${#unique[@]} - 20 ))
            if [[ $remaining -gt 0 ]]; then
                dim "  ... and $remaining more"
            fi
            break
        fi
    done

    echo ""
    echo -ne "  ${GREEN}▸${RESET} Continue anyway? [y/N] "
    local answer
    read -r answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
        log "Aborted."
        exit 0
    fi
}

# ─── Repo Picker ──────────────────────────────────────────────────────────────

find_repos() {
    local dirs
    IFS=':' read -ra dirs <<< "$REPO_DIRS"

    for base in "${dirs[@]}"; do
        [[ -d "$base" ]] || continue
        find "$base" -maxdepth 3 -name ".git" -type d 2>/dev/null | while read -r gitdir; do
            dirname "$gitdir"
        done
    done | sort -u
}

pick_repo() {
    local repos=()
    while IFS= read -r line; do
        repos+=("$line")
    done < <(find_repos)

    if [[ ${#repos[@]} -eq 0 ]]; then
        error "No git repos found in search paths."
        dim "Searched: ${REPO_DIRS//:/, }"
        dim "Set CLAUDE_SANDBOX_REPO_DIRS to customize, or pass a path directly."
        exit 1
    fi

    # Use fzf if available
    if command -v fzf &>/dev/null; then
        local picked
        picked=$(printf '%s\n' "${repos[@]}" | sed "s|${HOME}|~|g" | \
            fzf --height=20 --reverse --prompt="Pick a repo > " \
                --header="Only this repo will be mounted. Nothing else is accessible." \
                --preview="ls -la {}" 2>/dev/null) || { error "No repo selected."; exit 1; }
        picked="${picked/#\~/$HOME}"
        echo "$picked"
        return
    fi

    # Fallback: numbered menu
    echo "" >&2
    echo -e "${BOLD}Pick a repo to mount in the sandbox:${RESET}" >&2
    dim "Only this folder will be accessible. Your filesystem, home directory," >&2
    dim "and all other repos stay completely out of reach." >&2
    echo "" >&2

    local i=1
    for repo in "${repos[@]}"; do
        printf "  ${BOLD}%3d${RESET}  %s\n" "$i" "${repo/#$HOME/~}" >&2
        ((i++))
    done
    echo "" >&2

    local choice
    while true; do
        echo -ne "  ${GREEN}▸${RESET} Enter number (1-${#repos[@]}): " >&2
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#repos[@]} )); then
            echo "${repos[$((choice-1))]}"
            return
        fi
        warn "Invalid choice. Try again."
    done
}

# ─── MCP Server Picker ───────────────────────────────────────────────────────

find_mcp_configs() {
    local configs=()
    # Global MCP config
    if [[ -f "${HOME}/.claude/.mcp.json" ]]; then
        configs+=("${HOME}/.claude/.mcp.json")
    fi
    # Project-level MCP configs
    if [[ -n "${1:-}" && -f "${1}/.mcp.json" ]]; then
        configs+=("${1}/.mcp.json")
    fi
    printf '%s\n' "${configs[@]}"
}

list_mcp_servers() {
    local repo_path="${1:-}"
    local configs
    configs=$(find_mcp_configs "$repo_path")

    [[ -z "$configs" ]] && return
    command -v python3 &>/dev/null || return

    local config_list=""
    while IFS= read -r config; do
        [[ -z "$config" ]] && continue
        config_list="${config_list}${config_list:+,}\"${config}\""
    done <<< "$configs"

    python3 -c "
import json
configs = [${config_list}]
seen = {}
for config_path in configs:
    with open(config_path) as f:
        data = json.load(f)
    for name, server in data.get('mcpServers', {}).items():
        if name not in seen:
            cmd = server.get('command', '?')
            args = ' '.join(server.get('args', [])[:2])
            seen[name] = (cmd, args, config_path)
for name in sorted(seen):
    cmd, args, src = seen[name]
    print(f'{name}\t{cmd} {args}\t{src}')
" 2>/dev/null
}

pick_mcp_servers() {
    local repo_path="${1:-}"
    local servers=()
    local names=()
    local details=()

    while IFS=$'\t' read -r name detail source; do
        [[ -z "$name" ]] && continue
        names+=("$name")
        details+=("$detail")
        servers+=("$name")
    done < <(list_mcp_servers "$repo_path")

    if [[ ${#servers[@]} -eq 0 ]]; then
        return
    fi

    echo "" >&2
    echo -e "${BOLD}MCP servers found in your config:${RESET}" >&2
    dim "Select which ones to make available in the sandbox." >&2
    echo "" >&2

    local i=1
    for idx in "${!names[@]}"; do
        printf "  ${BOLD}%3d${RESET}  ${CYAN}%-20s${RESET}  ${DIM}%s${RESET}\n" "$i" "${names[$idx]}" "${details[$idx]}" >&2
        ((i++))
    done
    echo "" >&2
    echo -e "  ${DIM}Enter numbers separated by spaces, 'all', or 'none'${RESET}" >&2

    local choice
    echo -ne "  ${GREEN}▸${RESET} MCP servers: " >&2
    read -r choice

    if [[ "$choice" == "none" || -z "$choice" ]]; then
        return
    fi

    if [[ "$choice" == "all" ]]; then
        printf '%s\n' "${names[@]}"
        return
    fi

    for num in $choice; do
        if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#names[@]} )); then
            echo "${names[$((num-1))]}"
        fi
    done
}

build_mcp_config() {
    local repo_path="${1:-}"
    shift
    local selected=("$@")

    [[ ${#selected[@]} -eq 0 ]] && return

    local configs
    configs=$(find_mcp_configs "$repo_path")

    python3 -c "
import json, sys

selected = set(sys.argv[1:])
result = {'mcpServers': {}}

configs = '''$configs'''.strip().split('\n')
for config_path in configs:
    if not config_path:
        continue
    with open(config_path) as f:
        data = json.load(f)
    for name, server in data.get('mcpServers', {}).items():
        if name in selected:
            result['mcpServers'][name] = server

print(json.dumps(result, indent=2))
" "${selected[@]}" 2>/dev/null
}

# ─── Agent Picker ─────────────────────────────────────────────────────────────

find_agents() {
    local agent_dir="${HOME}/.claude/agents"
    [[ -d "$agent_dir" ]] || return

    find "$agent_dir" -name "*.md" -type f 2>/dev/null | sort
}

pick_agents() {
    local agents=()
    local names=()

    while IFS= read -r path; do
        [[ -z "$path" ]] && continue
        local name
        name="$(basename "$path" .md)"
        agents+=("$path")
        names+=("$name")
    done < <(find_agents)

    if [[ ${#agents[@]} -eq 0 ]]; then
        return
    fi

    echo "" >&2
    echo -e "${BOLD}Custom agents found:${RESET}" >&2
    dim "Select which ones to include in the sandbox." >&2
    echo "" >&2

    local i=1
    for name in "${names[@]}"; do
        printf "  ${BOLD}%3d${RESET}  %s\n" "$i" "$name" >&2
        ((i++))
    done
    echo "" >&2
    echo -e "  ${DIM}Enter numbers separated by spaces, 'all', or 'none'${RESET}" >&2

    local choice
    echo -ne "  ${GREEN}▸${RESET} Agents: " >&2
    read -r choice

    if [[ "$choice" == "none" || -z "$choice" ]]; then
        return
    fi

    if [[ "$choice" == "all" ]]; then
        printf '%s\n' "${agents[@]}"
        return
    fi

    for num in $choice; do
        if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#agents[@]} )); then
            echo "${agents[$((num-1))]}"
        fi
    done
}

